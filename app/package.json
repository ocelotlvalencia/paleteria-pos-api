{
  "name": "punto-de-venta-v001",
  "version": "1.0.0",
  "description": "Punto de Venta V.001",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.paleterianopalucan.pos",
    "productName": "Punto de Venta V.001",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "panel.html",
      "renderer.js",
      "styles.css",
      "build/icon.ico",
      "docs/**/*",
      "images/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "docs/paleteria-pos.config",
        "to": "paleteria-pos.config"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  }
}
