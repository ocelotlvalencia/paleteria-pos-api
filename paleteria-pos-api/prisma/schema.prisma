generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/* PRODUCTOS */

model Producto {

  id          Int      @id @default(autoincrement())

  nombre      String

  precio      Float

  precioMayoreo Float?

  cantidadMayoreo Int?

  categoria   String

  imagen      String?

  stock       Int      @default(0)

  createdAt   DateTime @default(now())
}

/* CLIENTES */

model Cliente {

  id          Int      @id @default(autoincrement())

  nombre      String

  telefono    String?

  createdAt   DateTime @default(now())
}

/* PROVEEDORES */

model Proveedor {

  id          Int      @id @default(autoincrement())

  nombre      String

  contacto    String?

  telefono    String?

  descripcion String?

  materias    MateriaPrima[]

  createdAt   DateTime @default(now())
}

/* MATERIA PRIMA */

model MateriaPrima {

  id          Int      @id @default(autoincrement())

  nombre      String

  stock       Float

  unidad      String

  proveedorId Int?

  proveedor   Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}

/* VENTAS */

model Venta {

  id            Int      @id @default(autoincrement())

  total         Float

  metodoPago    String

  items         Json?

  createdAt     DateTime @default(now())
}

/* PEDIDOS */

model Pedido {

  id            Int      @id @default(autoincrement())

  cliente       String

  telefono      String?

  detalle       String

  fechaEntrega  DateTime

  estado        String   @default("Pendiente")

  total         Float    @default(0)

  createdAt     DateTime @default(now())
}
