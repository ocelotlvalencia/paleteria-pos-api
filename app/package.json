{
  "name": "paleteria-pos-app",
  "version": "1.0.0",
  "description": "Paleteria Nopalucan POS",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.paleterianopalucan.pos",
    "productName": "Paleteria Nopalucan POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "panel.html",
      "renderer.js",
      "styles.css",
      "images/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron": "^41.5.0"
  },
  "devDependencies": {
    "electron-builder": "^26.8.1"
  }
}
